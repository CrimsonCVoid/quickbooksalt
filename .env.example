# ============================================
# Carolina Comfort HVAC — Invoicing — Environment Variables
# Copy to .env.local for local dev, set in Vercel for prod.
# ============================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# OWNER_EMAIL accepts a single email or a comma-separated list — every listed email
# is allowed to sign in to /admin. Useful for a primary work email + personal backup.
OWNER_EMAIL=carter@carolinacomfort.info,wcarterbrady00@gmail.com

# --- Supabase ---
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Resend (email) ---
# resend.com → API Keys
RESEND_API_KEY=re_...
# Verified sender — must be on a domain you've added DNS records for in Resend
RESEND_FROM_EMAIL=billing@carolinacomfort.info
RESEND_REPLY_TO=carter@carolinacomfort.info

# --- Stripe (DISABLED for now — uncomment when you want to enable online payments) ---
# All clients currently pay by check; record check# + deposit date on the invoice page.
# To re-enable: fill these in, set settings.stripe_enabled = true in the DB, and
# restore the toggle in components/settings-form.tsx (see "disabled" label there).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Cron (Vercel-set; dev only needs CRON_SECRET) ---
CRON_SECRET=generate-a-long-random-string
