# ============================================
# Filter Monkey Invoicing — Environment Variables
# Copy to .env.local for local dev, set in Vercel for prod.
# ============================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
OWNER_EMAIL=carter@carolinacomfort.info

# --- Supabase ---
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Resend (email) ---
# resend.com → API Keys
RESEND_API_KEY=re_...
# Verified sender — must be on a domain you've added DNS records for in Resend
RESEND_FROM_EMAIL=billing@filtermonkey.com
RESEND_REPLY_TO=carter@carolinacomfort.info

# --- Stripe (optional online pay path — used for the rare client who pays online) ---
# stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Cron (Vercel-set; dev only needs CRON_SECRET) ---
CRON_SECRET=generate-a-long-random-string
